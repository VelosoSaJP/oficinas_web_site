---
import Layout from '../layouts/Layout.astro';

const funcionalidades = [
  {
    titulo: 'Leitura automática por RFID',
    descricao: 'O leitor RC522 conectado ao ESP32 identifica produtos por etiquetas RFID passivas, eliminando a necessidade de input manual no momento da entrada ou saída de itens.',
    status: 'Planejado',
  },
  {
    titulo: 'Medição de estoque por peso',
    descricao: 'Célula de carga com módulo HX711 calcula automaticamente a quantidade de produto pela variação de peso, ideal para itens vendidos a granel.',
    status: 'Planejado',
  },
  {
    titulo: 'CRUD de inventário',
    descricao: 'Interface web para cadastro, edição, consulta e remoção de produtos no estoque, com banco de dados SQLite para persistência local.',
    status: 'Planejado',
  },
  {
    titulo: 'Atualização automática de estoque',
    descricao: 'O sistema atualiza as quantidades em tempo real à medida que produtos são lidos pelo RFID ou pesados, mantendo o inventário sempre sincronizado.',
    status: 'Planejado',
  },
  {
    titulo: 'Pagamento via Pix com QR Code dinâmico',
    descricao: 'Integração com a API do Mercado Pago para geração de QR Code de cobrança no momento da transação, permitindo pagamento imediato via Pix.',
    status: 'Planejado',
  },
  {
    titulo: 'Modo administrador',
    descricao: 'Acesso restrito por autenticação para operações sensíveis, como cadastro de novos produtos, ajuste de preços e visualização de relatórios.',
    status: 'Planejado',
  },
  {
    titulo: 'Reserva temporária de itens',
    descricao: 'Durante uma transação em andamento, os itens selecionados ficam reservados temporariamente para evitar conflitos de estoque entre múltiplas operações simultâneas.',
    status: 'Planejado',
  },
];
---

<Layout title="Funcionalidades" description="O que foi desenvolvido no projeto">
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Funcionalidades</h1>
      <p class="text-gray-500 mb-12">O que foi desenvolvido e entregue no projeto.</p>

      <div class="space-y-6">
        {funcionalidades.map((item, i) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex items-start gap-4">
            <span class="text-indigo-600 font-bold text-lg w-8 shrink-0">{i + 1}.</span>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-semibold text-gray-900">{item.titulo}</h3>
                <span class={`text-xs font-medium px-2 py-1 rounded-full ${
                  item.status === 'Concluída'
                    ? 'bg-green-100 text-green-700'
                    : 'bg-yellow-100 text-yellow-700'
                }`}>
                  {item.status}
                </span>
              </div>
              <p class="text-gray-600 text-sm">{item.descricao}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
