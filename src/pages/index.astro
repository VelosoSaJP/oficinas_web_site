---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="bg-indigo-50 py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">
        ./inventário
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Sistema automatizado de controle de estoque com tecnologia RFID e balança integrada — desenvolvido para eliminar erros do inventário manual em pequenos negócios.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/sobre" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
          Saiba mais
        </a>
        <a href="/resultados" class="border border-indigo-600 text-indigo-600 px-6 py-3 rounded-lg font-medium hover:bg-indigo-50 transition-colors">
          Ver resultados
        </a>
      </div>
    </div>
  </section>

  <!-- Destaques -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-center text-gray-900 mb-12">Destaques</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { title: 'Leitura RFID Automática', desc: 'Identificação instantânea de produtos com leitor RC522 e ESP32, sem necessidade de input manual.' },
          { title: 'Pagamento via Pix', desc: 'Geração dinâmica de QR Code integrada à API do Mercado Pago para cobrança automática.' },
          { title: 'Estoque por Peso', desc: 'Célula de carga com módulo HX711 calcula quantidade automaticamente por variação de peso.' },
        ].map(item => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h3 class="font-semibold text-lg text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
